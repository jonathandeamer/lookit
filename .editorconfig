# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Go is tab-indented (gofmt enforces this).
[*.go]
indent_style = tab

# Make requires tab-indented recipes.
[Makefile]
indent_style = tab

# Trailing whitespace is significant in Markdown (two spaces = hard line break).
[*.md]
trim_trailing_whitespace = false
